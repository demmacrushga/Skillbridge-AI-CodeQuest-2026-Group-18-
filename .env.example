POSTGRES_DB=skillbridge_db
POSTGRES_USER=skillbridge
POSTGRES_PASSWORD=change_me_strong_password

# Must be Base64-encoded, minimum 32 bytes (256 bits) for HMAC-SHA256
# Generate with: openssl rand -base64 32
JWT_SECRET=change_me_base64_encoded_32_byte_minimum_secret
JWT_EXPIRY_HOURS=24

# Anthropic Claude API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Directory for CV file uploads (skill-gap-service)
FILE_UPLOAD_DIR=/app/uploads

# Portfolio service database name (shares the main POSTGRES_DB schema)
PORTFOLIO_DB_NAME=skillbridge_db

# Internal service-to-service token for notification-service ingestion endpoint
# Generate with: openssl rand -base64 32
INTERNAL_SERVICE_TOKEN=change_me_base64_encoded_internal_service_token
